rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /players/{playerId} {
      allow read, write: if request.auth != null;

      match /statEntries/{entryId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          request.auth.token.email.lower() in ['angelismejia06@gmail.com', 'proniw83@gmail.com'];
      }
    }

    match /games/{gameId} {
      allow read, write: if request.auth != null;

      match /rounds/{roundId} {
        allow read, write: if request.auth != null;
      }
    }

    // Espacio propio de quien no es parte de la familia: solo el dueño
    // (mismo uid) puede leer o escribir su propia liga personal.
    match /guestSpaces/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
