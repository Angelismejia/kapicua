rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Admin = correo en la lista fija (respaldo) o con documento propio
    // en la coleccion "admins" (otorgado desde la app por otro admin).
    function isAdmin() {
      return request.auth != null &&
        (request.auth.token.email.lower() in
          ['angelismejia06@gmail.com', 'proniw83@gmail.com'] ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // Cuenta real de la familia (correo y contrasena), no un invitado
    // anonimo. Los invitados tienen su propio espacio aislado
    // (guestSpaces) y no deben poder tocar los datos compartidos de la
    // familia aunque tengan sesion (anonima) iniciada.
    function isFamilyMember() {
      return request.auth != null &&
        request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Lectura: cualquiera con cuenta puede ver quien es admin (para la
    // pantalla de dar permisos). Escritura: solo un admin puede nombrar
    // o quitar a otro.
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Ganador declarado a mano por un admin para un mes sin ninguna
    // ganada/perdida registrada (ej. antes de usar la app).
    match /monthlyOverrides/{monthKey} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /players/{playerId} {
      // Lectura publica (solo nombres/foto, sin estadisticas) para poder
      // elegir tu jugador de la lista al registrarte, antes de crear la
      // cuenta. El PIN familiar es el filtro real de quien se une.
      allow read: if true;

      // Crear un jugador nuevo (ej. al registrarse) lo puede hacer
      // cualquier cuenta real de la familia.
      allow create: if isFamilyMember();

      // Editar un jugador ya existente: un admin puede editar cualquier
      // campo; alguien de la familia solo puede (a) cambiar su propia
      // foto, o (b) vincularse a un jugador todavia sin cuenta (authUid
      // nulo) poniendo su propio uid. Nada mas, para que nadie pueda
      // robarse la identidad de otro jugador ni cambiarle el nombre.
      allow update: if isAdmin() ||
        (isFamilyMember() &&
         resource.data.authUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['photoBase64'])) ||
        (isFamilyMember() &&
         resource.data.authUid == null &&
         request.resource.data.authUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['authUid']));

      allow delete: if isAdmin();

      match /statEntries/{entryId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
      }
    }

    // Regla aparte (con comodin) para las consultas "collection group" de
    // statEntries (buscan en todas las subcolecciones a la vez): la regla
    // anidada de arriba no alcanza a cubrir ese tipo de consulta.
    match /{path=**}/statEntries/{entryId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /games/{gameId} {
      allow read, write: if isFamilyMember();

      match /rounds/{roundId} {
        allow read, write: if isFamilyMember();
      }
    }

    // Espacio propio de quien no es parte de la familia: solo el dueño
    // (mismo uid) puede leer o escribir su propia liga personal.
    match /guestSpaces/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
